# Üretim ortamında tam URL (Open Graph ve sitemap için)
NEXT_PUBLIC_SITE_URL=https://example.com

# Ana sayfa GitHub repoları bileşeni — sadece kullanıcı adı (ör. octocat)
NEXT_PUBLIC_GITHUB_USERNAME=UmutCingisiz

# Auth.js (GitHub OAuth — Ziyaretçi defteri için)
# Üretim ve geliştirmede kullan: `npx auth secret`
AUTH_SECRET=
# İsteğe bağlı; üretimde genelde site kök URL’si
AUTH_URL=http://localhost:3000
# GitHub OAuth uygulaması: https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Neon Postgres (guestbook + iletişim guard tabloları için Drizzle)
DATABASE_URL=

# Virgülle ayrılmış GitHub kullanıcı ID’leri (moderasyon).
GUESTBOOK_ADMIN_GITHUB_IDS=

GUESTBOOK_RATE_PER_MINUTE=5
GUESTBOOK_RATE_PER_DAY=30

# Upstash Redis (Vercel Marketplace — blog görüntülenmesi ve CV sayacı)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (iletişim formu — gönderen adresi domain doğrulanmış olmalı)
RESEND_API_KEY=
CONTACT_FROM_EMAIL=noreply@senin-domainin.dev
CONTACT_NOTIFY_EMAIL=sen@sirket.email

# Production observability provider (Sentry, Axiom veya Datadog)
OBSERVABILITY_PROVIDER=
OBSERVABILITY_DSN=
