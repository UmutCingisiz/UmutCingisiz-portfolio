# Üretim ortamında tam URL (Open Graph ve sitemap için) — markdown link değil, düz URL
# UYARI: .env.local / Vercel değerlerini ekran görüntüsüyle paylaşma. Sızıntıda rotate et (docs/MANUEL-ADIMLAR.md §0).
NEXT_PUBLIC_SITE_URL=https://umutcingisiz.com

# Ana sayfa GitHub repoları bileşeni — sadece kullanıcı adı (ör. octocat)
NEXT_PUBLIC_GITHUB_USERNAME=UmutCingisiz

# Auth.js (GitHub OAuth — Ziyaretçi defteri için)
# Üretim ve geliştirmede kullan: `npx auth secret` veya:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
# Yerelde: http://localhost:3000  |  Production (Vercel): https://umutcingisiz.com
AUTH_URL=http://localhost:3000
# GitHub OAuth uygulaması: https://github.com/settings/developers
# Callback (production): https://umutcingisiz.com/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Neon Postgres (guestbook + iletişim guard tabloları için Drizzle)
DATABASE_URL=

# Virgülle ayrılmış GitHub kullanıcı ID’leri (moderasyon).
GUESTBOOK_ADMIN_GITHUB_IDS=

GUESTBOOK_RATE_PER_MINUTE=5
GUESTBOOK_RATE_PER_DAY=30

# Upstash Redis — kurulana kadar Vercel'e EKLEME (boş string koyma; kod yoksa no-op)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Resend — domain doğrulanıp API key alınana kadar Vercel'e EKLEME
# RESEND_API_KEY=
CONTACT_FROM_EMAIL=noreply@umutcingisiz.com
CONTACT_NOTIFY_EMAIL=cingisizumut1@gmail.com

# Production observability — Sentry (isteğe bağlı)
# OBSERVABILITY_PROVIDER=sentry
# OBSERVABILITY_DSN=          # server fallback
# NEXT_PUBLIC_SENTRY_DSN=     # client + server (DSN ile aynı değer)
# SENTRY_AUTH_TOKEN=          # source map upload (yalnızca Vercel/CI; sohbete yapıştırma)
